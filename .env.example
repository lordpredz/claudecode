# Caminho do binário do whisper.cpp compilado (scripts/setup-vps.sh gera em
# whisper.cpp/build/bin/whisper-cli)
WHISPER_BIN=./whisper.cpp/build/bin/whisper-cli

# Caminho do modelo ggml usado na transcrição. "small" tem boa precisão e
# cabe com folga em 4GB de RAM já que o resumo roda fora da VPS (Groq/Gemini/
# Claude); troque pra "base" se quiser priorizar RAM (ex: usando Ollama local).
WHISPER_MODEL=./whisper.cpp/models/ggml-small.bin

# Idioma forçado na transcrição (pt = português). Use "auto" para detecção automática.
WHISPER_LANG=pt

# Qual provedor usar para gerar o resumo: "groq" (nuvem, camada grátis, sem
# cartão), "gemini" (nuvem, camada grátis do Google), "ollama" (local, grátis)
# ou "claude" (nuvem, paga, melhor qualidade)
SUMMARY_PROVIDER=groq

# --- Provedor "groq" (SUMMARY_PROVIDER=groq) ---
# Chave grátis em console.groq.com/keys. NÃO compartilhe essa chave.
GROQ_API_KEY=
# Modelo usado para o resumo
GROQ_MODEL=llama-3.3-70b-versatile

# --- Provedor "gemini" (SUMMARY_PROVIDER=gemini) ---
# Chave grátis em aistudio.google.com/apikey. NÃO compartilhe essa chave.
GEMINI_API_KEY=
# Modelo usado para o resumo
GEMINI_MODEL=gemini-2.0-flash

# --- Provedor "ollama" (SUMMARY_PROVIDER=ollama) ---
# URL do servidor Ollama local
OLLAMA_URL=http://127.0.0.1:11434
# Modelo usado para gerar o resumo
OLLAMA_MODEL=llama3.2:3b-instruct-q4_K_M
# Temperatura (0 a 1). Mais baixo = respostas mais consistentes/previsíveis
# entre chamadas parecidas; mais alto = mais variação.
OLLAMA_TEMPERATURE=0.3

# --- Provedor "claude" (SUMMARY_PROVIDER=claude) ---
# Chave da API da Anthropic (console.anthropic.com). NÃO compartilhe essa chave.
ANTHROPIC_API_KEY=
# Modelo usado para o resumo
CLAUDE_MODEL=claude-opus-4-8

# Tempo de inatividade (ms) antes de agrupar as mensagens recebidas e gerar o resumo
DEBOUNCE_MS=8000
